            },
            "description": "Agent service API key fallback"
          },
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project review statistics"
          }
        }
      }
    },
    "/api/agent/automation/code-review/retry": {
      "post": {
        "operationId": "retryFailedCodeReview",
