    "/api/agent/automation/tasks/{task_id}/git-activity": {
      "get": {
        "operationId": "getTaskGitActivity",
        "summary": "Get ticket-linked git activity",
        "description": "Return branches, commits, and pull requests related to the provided ticket/task ID.",
        "security": [
          {
            "AgentAPIKeyHeader": []
          },
          {
            "AgentAPIKeyQuery": []
          },
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "LX5HETBWgbO0IqOaWVu5Cs__B2ovKG_yfFu70dqpQy_mLjL0YIAfTBR-7570Q_tf"
            },
            "description": "Agent service API key fallback"
          },
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Task _id or ticket ID"
          },
          {
            "name": "requesting_user",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket-linked branch, commit, and PR activity"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AgentAPIKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Agent-Key",
        "description": "Preferred auth key transport for Foundry connector"
      },
      "AgentAPIKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Agent service authentication key in query parameter",
        "x-default": "LX5HETBWgbO0IqOaWVu5Cs__B2ovKG_yfFu70dqpQy_mLjL0YIAfTBR-7570Q_tf"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token compatibility channel"
      }
    }
  }
}