        "security": [
          {
            "AgentAPIKeyHeader": []
          },
          {
            "AgentAPIKeyQuery": []
          },
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "LX5HETBWgbO0IqOaWVu5Cs__B2ovKG_yfFu70dqpQy_mLjL0YIAfTBR-7570Q_tf"
            },
            "description": "Agent service API key fallback"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "review_id"
                ],
                "properties": {
                  "requesting_user": {
                    "type": "string",
                    "format": "email"
                  },
                  "review_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retry queued"
          }
        }
      }
    },
    "/api/agent/automation/code-review/health": {
      "get": {
